#!/usr/bin/env bash
set -eo pipefail

TIMEOUT=30
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(dirname "$SCRIPT_DIR")"
AUTOGRADER_DIR="$(dirname "$TESTS_DIR")"
ROOT_DIR="$(dirname "$AUTOGRADER_DIR")"
SRC_DIR="${ROOT_DIR}/src"
LOG_FILE="${SCRIPT_DIR}/cppcheck.log"
SUPPRESSIONS_FILE="${SCRIPT_DIR}/suppressions.txt"

: > "$LOG_FILE"

log() {
    echo "$@" | tee -a "$LOG_FILE"
}

if ! command -v cppcheck >/dev/null 2>&1; then
    log "Error: cppcheck no esta instalado"
    exit 1
fi

FILES=(
    "${SCRIPT_DIR}/cppcheck.cpp"
    "${SRC_DIR}/drone_system.cpp"
    "${SRC_DIR}/drone_system.h"
)

EXIT_CODE=0
for fullpath in "${FILES[@]}"; do
    if [[ ! -f "$fullpath" ]]; then
        log "Warning: archivo no encontrado - $fullpath"
        EXIT_CODE=1
        continue
    fi

    log "Analizando $(basename "$fullpath") con cppcheck..."

    if ! timeout "$TIMEOUT" cppcheck \
        --enable=warning,style,performance,portability,information \
        --std=c++23 \
        --language=c++ \
        --error-exitcode=1 \
        --inline-suppr \
        --suppressions-list="$SUPPRESSIONS_FILE" \
        -I"$SRC_DIR" \
        "$fullpath" 2>&1 | tee -a "$LOG_FILE"; then
        if [[ "${PIPESTATUS[0]}" -eq 124 ]]; then
            log "Timeout excedido al analizar $(basename "$fullpath")"
        fi
        EXIT_CODE=1
    fi
done

if [[ "$EXIT_CODE" -eq 0 ]]; then
    log "Cppcheck: todos los checks pasaron"
else
    log "Cppcheck: se encontraron problemas"
fi

gzip -f "$LOG_FILE"

exit "$EXIT_CODE"
