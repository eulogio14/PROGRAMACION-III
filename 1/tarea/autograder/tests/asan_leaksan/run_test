#!/usr/bin/env bash
set -eo pipefail

TIMEOUT=30
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(dirname "$SCRIPT_DIR")"
AUTOGRADER_DIR="$(dirname "$TESTS_DIR")"
ROOT_DIR="$(dirname "$AUTOGRADER_DIR")"
SRC_DIR="${ROOT_DIR}/src"
BUILD_DIR="${SCRIPT_DIR}/build"
LOG_FILE="${SCRIPT_DIR}/asan-leaksan.log"
OUTPUT_BIN="${BUILD_DIR}/asan_leaksan_check"

: > "$LOG_FILE"
mkdir -p "$BUILD_DIR"

log() {
    echo "$@" | tee -a "$LOG_FILE"
}

COMPILER=""
if command -v clang++ >/dev/null 2>&1; then
    COMPILER="clang++"
elif command -v g++ >/dev/null 2>&1; then
    COMPILER="g++"
else
    log "Error: no se encontro clang++ ni g++"
    exit 1
fi

log "Compilando smoke test con AddressSanitizer y LeakSanitizer..."

if ! "$COMPILER" \
    -std=c++23 \
    -g \
    -O1 \
    -fsanitize=address,leak,undefined \
    -fno-omit-frame-pointer \
    -I"${SRC_DIR}" \
    "${SCRIPT_DIR}/asan_leaksan.cpp" \
    "${SRC_DIR}/drone_system.cpp" \
    -o "$OUTPUT_BIN" 2>&1 | tee -a "$LOG_FILE"; then
    log "Fallo la compilacion del check ASan/LSan"
    gzip -f "$LOG_FILE"
    exit 1
fi

log "Ejecutando smoke test instrumentado..."

if ! ASAN_OPTIONS=detect_leaks=1:halt_on_error=1 UBSAN_OPTIONS=halt_on_error=1 \
    timeout "$TIMEOUT" "$OUTPUT_BIN" 2>&1 | tee -a "$LOG_FILE"; then
    if [[ "${PIPESTATUS[0]}" -eq 124 ]]; then
        log "Timeout excedido durante la ejecucion instrumentada"
    else
        log "ASan/LSan detecto un problema"
    fi
    gzip -f "$LOG_FILE"
    exit 1
fi

log "ASan/LSan: ejecucion sin errores ni fugas detectadas"
gzip -f "$LOG_FILE"

exit 0
